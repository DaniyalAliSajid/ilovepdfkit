---
import BlogLayout from '../layouts/BlogLayout.astro';
import SEO from '../components/SEO.astro';
import Schema from '../components/Schema.astro';
import AuthorBox from '../components/AuthorBox.astro';
import { Image } from 'astro:assets';
import { getAllPosts, getExcerpt, getFeaturedImage, getAuthor } from '../lib/wordpress';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const image = getFeaturedImage(post);
const author = getAuthor(post);
const excerpt = getExcerpt(post);
const categories = post._embedded?.['wp:term']?.[0] || [];
const canonical = `https://ilovepdfkit.com/blog/${post.slug}`;
---

<BlogLayout>
  <SEO
    slot="head"
    title={post.title.rendered}
    description={excerpt}
    canonical={canonical}
    image={image?.url}
    type="article"
    publishedTime={post.date}
    modifiedTime={post.modified}
  />
  
  <Schema
    slot="head"
    headline={post.title.rendered}
    description={excerpt}
    datePublished={post.date}
    dateModified={post.modified}
    authorName={author.name}
    url={canonical}
    image={image?.url}
  />
  
  <article class="post">
    <header class="post-header">
      <div class="post-categories">
        {categories.map(cat => (
          <a href={`/blog/category/${cat.slug}`} class="category-tag">{cat.name}</a>
        ))}
      </div>
      <h1>{post.title.rendered}</h1>
      <div class="post-meta">
        <span class="author">By {author.name}</span>
        <span class="separator">•</span>
        <time datetime={post.date}>
          {new Date(post.date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          })}
        </time>
      </div>
    </header>
    
    {image && (
      <Image 
        src={image.url} 
        alt={image.alt} 
        width={1200} 
        height={630} 
        class="featured-image"
        widths={[400, 800, 1200]}
        sizes="(max-width: 800px) 100vw, 800px"
        format="webp"
      />
    )}
    
    <div class="post-content" set:html={post.content.rendered} />
    
    <AuthorBox name={author.name} avatar={author.avatar} />

    <!-- Conversion CTA Section -->
    <div class="conversion-cta">
      <h3>Ready to convert your PDFs?</h3>
      <p>Try our free, fast, and secure PDF conversion tools now!</p>
      <a href="/#tools-section" class="cta-button">Get Started →</a>
    </div>
  </article>
</BlogLayout>

<style>
  .post {
    max-width: 850px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }
  
  .post-header {
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .post-categories {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .category-tag {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    background: #f5f3ff;
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    transition: all 0.2s;
  }

  .category-tag:hover {
    background: var(--color-primary);
    color: white;
  }
  
  .post-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.2;
    margin-bottom: 1.5rem;
    color: var(--color-text);
  }
  
  .post-meta {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text-light);
    font-size: 0.9375rem;
  }

  .separator {
    color: #d1d5db;
  }
  
  .featured-image {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 1rem;
    margin-bottom: 3rem;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
  }
  
  .post-content {
    font-size: 1.125rem;
    line-height: 1.8;
  }
  
  .post-content :global(h2) {
    font-size: 2rem;
    margin: 3rem 0 1.5rem;
    color: var(--color-text);
  }
  
  .post-content :global(h3) {
    font-size: 1.5rem;
    margin: 2rem 0 1rem;
    color: var(--color-text);
  }
  
  .post-content :global(p) {
    margin-bottom: 1.5rem;
  }
  
  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 0.75rem;
    margin: 2rem 0;
  }
  
  .post-content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    font-weight: 500;
  }

  .post-content :global(ul), .post-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.5rem;
  }
  
  .conversion-cta {
    margin-top: 4rem;
    padding: 3rem;
    background: linear-gradient(135deg, #f5f3ff 0%, #ede9fe 100%);
    border-radius: 1.5rem;
    text-align: center;
    border: 1px solid #ddd6fe;
  }
  
  .conversion-cta h3 {
    font-size: 2rem;
    margin-bottom: 1rem;
    color: var(--color-text);
  }
  
  .conversion-cta p {
    font-size: 1.125rem;
    color: var(--color-text-light);
    margin-bottom: 2rem;
  }
  
  .cta-button {
    display: inline-block;
    background: var(--color-primary);
    color: white !important;
    padding: 1rem 2.5rem;
    border-radius: 0.75rem;
    font-weight: 600;
    font-size: 1.125rem;
    text-decoration: none;
    transition: all 0.2s;
    box-shadow: 0 10px 15px -3px rgba(139, 92, 246, 0.3);
  }
  
  .cta-button:hover {
    background: #7c3aed;
    transform: translateY(-2px);
    box-shadow: 0 20px 25px -5px rgba(139, 92, 246, 0.4);
  }
</style>
