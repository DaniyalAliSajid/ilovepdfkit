---
import BlogLayout from '../layouts/BlogLayout.astro';
import SEO from '../components/SEO.astro';
import Schema from '../components/Schema.astro';
import { getAllPosts, getExcerpt, getFeaturedImage, getAuthor } from '../lib/wordpress';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const image = getFeaturedImage(post);
const author = getAuthor(post);
const excerpt = getExcerpt(post);
const canonical = `https://ilovepdfkit.com/blog/${post.slug}`;
---

<BlogLayout>
  <SEO
    slot="head"
    title={post.title.rendered}
    description={excerpt}
    canonical={canonical}
    image={image?.url}
    type="article"
    publishedTime={post.date}
    modifiedTime={post.modified}
  />
  
  <Schema
    slot="head"
    headline={post.title.rendered}
    description={excerpt}
    datePublished={post.date}
    dateModified={post.modified}
    authorName={author.name}
    url={canonical}
    image={image?.url}
  />
  
  <article class="post">
    <header class="post-header">
      <h1>{post.title.rendered}</h1>
      <div class="post-meta">
        <span class="author">{author.name}</span>
        <time datetime={post.date}>
          {new Date(post.date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          })}
        </time>
      </div>
    </header>
    
    {image && (
      <img src={image.url} alt={image.alt} class="featured-image" loading="lazy" />
    )}
    
    <div class="post-content" set:html={post.content.rendered} />
    
    <!-- Conversion CTA Section -->
    <div class="conversion-cta">
      <h3>Ready to convert your PDFs?</h3>
      <p>Try our free, fast, and secure PDF conversion tools now!</p>
      <a href="/#tools-section" class="cta-button">Get Started →</a>
    </div>
  </article>
</BlogLayout>

<style>
  .post {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }
  
  .post-header {
    margin-bottom: 2rem;
  }
  
  .post-header h1 {
    font-size: 2.5rem;
    line-height: 1.2;
    margin-bottom: 1rem;
  }
  
  .post-meta {
    display: flex;
    gap: 1rem;
    color: var(--color-text-light);
    font-size: 0.875rem;
  }
  
  .featured-image {
    width: 100%;
    height: auto;
    border-radius: 0.5rem;
    margin-bottom: 2rem;
  }
  
  .post-content {
    font-size: 1.125rem;
    line-height: 1.8;
  }
  
  .post-content :global(h2) {
    font-size: 2rem;
    margin: 2rem 0 1rem;
  }
  
  .post-content :global(h3) {
    font-size: 1.5rem;
    margin: 1.5rem 0 0.75rem;
  }
  
  .post-content :global(p) {
    margin-bottom: 1.5rem;
  }
  
  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
  }
  
  .post-content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
  }
  
  .conversion-cta {
    margin-top: 4rem;
    padding: 2.5rem;
    background: linear-gradient(135deg, #f5f3ff 0%, #ede9fe 100%);
    border-radius: 1rem;
    text-align: center;
    border: 2px solid #ddd6fe;
  }
  
  .conversion-cta h3 {
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }
  
  .conversion-cta p {
    font-size: 1.125rem;
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
  }
  
  .cta-button {
    display: inline-block;
    background: var(--color-primary);
    color: white;
    padding: 0.875rem 2rem;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: all 0.2s;
    box-shadow: 0 4px 12px rgba(139, 92, 246, 0.3);
  }
  
  .cta-button:hover {
    background: #7c3aed;
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(139, 92, 246, 0.4);
  }
</style>
