---
// Enhanced BlogFooter matching main site design with comprehensive links
---

<footer class="blog-footer">
  <div class="footer-content">
    <div class="footer-brand">
      <img src="/logo.webp" alt="iLovePDFKit" width="180" height="48" />
      <p class="tagline">Free, secure, and fast PDF conversion tools</p>
    </div>
    
    <div class="footer-links">
      <div class="footer-column">
        <h4>Product</h4>
        <a href="/">Home</a>
        <a href="/about">About Us</a>
        <a href="/blog">Blog</a>
        <a href="/api-docs">Developer API</a>
      </div>
      
      <div class="footer-column">
        <h4>Tools</h4>
        <a href="/pdf-to-word">PDF to Word</a>
        <a href="/word-to-pdf">Word to PDF</a>
        <a href="/pdf-to-jpg">PDF to JPG</a>
        <a href="/merge-pdf">Merge PDF</a>
      </div>
      
      <div class="footer-column">
        <h4>Legal</h4>
        <a href="/privacy-policy">Privacy Policy</a>
        <a href="/terms-and-conditions">Terms & Conditions</a>
      </div>
      
      <div class="footer-column">
        <h4>Connect</h4>
        <a href="/contact">Contact Us</a>
        <a href="/advertise-with-us">Advertise</a>
        <a href="https://github.com/DaniyalAliSajid/ilovepdfkit" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="display: inline; vertical-align: middle; margin-right: 4px;">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </a>
      </div>
    </div>
  </div>
  
  <div class="footer-bottom">
    <p>© {new Date().getFullYear()} iLovePDFKit. All rights reserved.</p>
    <p class="made-with">Made with ❤️ for seamless document conversion</p>
  </div>
</footer>

<style>
  .blog-footer {
    background: linear-gradient(180deg, #f9fafb 0%, #ffffff 100%);
    border-top: 1px solid #e5e7eb;
    padding: 3rem 2rem 1.5rem;
    margin-top: 4rem;
  }
  
  .footer-content {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 3rem;
    margin-bottom: 2rem;
  }
  
  .footer-brand img {
    margin-bottom: 1rem;
  }
  
  .tagline {
    color: var(--color-text-light);
    font-size: 0.875rem;
    line-height: 1.5;
  }
  
  .footer-links {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
  
  .footer-column h4 {
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text);
  }
  
  .footer-column a {
    display: block;
    color: var(--color-text-light);
    font-size: 0.875rem;
    margin-bottom: 0.75rem;
    transition: color 0.2s;
    text-decoration: none;
  }
  
  .footer-column a:hover {
    color: var(--color-primary);
  }
  
  .footer-bottom {
    max-width: var(--max-width);
    margin: 0 auto;
    padding-top: 2rem;
    border-top: 1px solid #e5e7eb;
    text-align: center;
  }
  
  .footer-bottom p {
    color: var(--color-text-light);
    font-size: 0.875rem;
    margin-bottom: 0.5rem;
  }
  
  .made-with {
    font-size: 0.8125rem;
  }
  
  @media (max-width: 1024px) {
    .footer-links {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    
    .footer-links {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
