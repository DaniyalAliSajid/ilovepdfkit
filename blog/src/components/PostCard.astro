---
interface Props {
  title: string;
  excerpt: string;
  slug: string;
  date: string;
  image?: { url: string; alt: string };
}

const { title, excerpt, slug, date, image } = Astro.props;
---

<article class="post-card">
  {image && (
    <a href={`/blog/${slug}`} class="post-image-link">
      <img src={image.url} alt={image.alt} class="post-image" loading="lazy" />
    </a>
  )}
  
  <div class="post-content">
    <h2>
      <a href={`/blog/${slug}`}>{title}</a>
    </h2>
    <p class="excerpt">{excerpt}</p>
    <time datetime={date}>
      {new Date(date).toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      })}
    </time>
  </div>
</article>

<style>
  .post-card {
    border: 1px solid var(--gray-200);
    border-radius: 0.75rem;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    background: white;
  }
  
  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
  }
  
  .post-image-link {
    display: block;
  }
  
  .post-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }
  
  .post-content {
    padding: 1.5rem;
  }
  
  .post-content h2 {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }
  
  .post-content h2 a {
    color: var(--color-text);
    transition: color 0.2s;
  }
  
  .post-content h2 a:hover {
    color: var(--color-primary);
  }
  
  .excerpt {
    color: var(--color-text-light);
    margin-bottom: 1rem;
    line-height: 1.6;
  }
  
  time {
    font-size: 0.875rem;
    color: var(--color-text-light);
  }
</style>
